{
  "functions": {
    "api/admin/index.js": { "maxDuration": 30 },
    "api/admin/save.js": { "maxDuration": 15 },
    "api/submissions.js": { "maxDuration": 15 },
    "api/subscribe.js": { "maxDuration": 15 },
    "api/translate.js": { "maxDuration": 15 },
    "api/custom-form-submit.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/admin/api/content.php", "destination": "/api/content" },
    { "source": "/admin/api/submissions.php", "destination": "/api/submissions" },
    { "source": "/admin/api/subscribe.php", "destination": "/api/subscribe" },
    { "source": "/admin/api/translate.php", "destination": "/api/translate" },
    { "source": "/admin/api/save.php", "destination": "/api/admin/save" },
    { "source": "/admin/login.php", "destination": "/api/admin/login" },
    { "source": "/admin/logout.php", "destination": "/api/admin/logout" },
    { "source": "/admin/index.php", "destination": "/api/admin/index" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https: data: blob:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://gsjhhbzjeiuvcjfazijw.supabase.co https://api.cognitive.microsofttranslator.com; frame-src https://www.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
