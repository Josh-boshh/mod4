# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# MySQL database connection (also accepts DATABASE_URL directly)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mod3
DB_USER=mod3_user
DB_PASS=
DATABASE_URL=

# Security key for IP hashing (min 32 random chars)
SPAM_IP_HASH_KEY=

# Microsoft Azure Translator (optional — enables live translation)
AZURE_TRANSLATE_KEY=
AZURE_TRANSLATE_REGION=westeurope

# Auth — signs the admin session JWT cookie (min 32 random chars)
JWT_SECRET=

# Vercel Blob — file uploads (hero/press/gallery/headshot images, tender/report docs)
BLOB_READ_WRITE_TOKEN=

# One-time setup gate — required to POST /api/admin/setup successfully
SETUP_SECRET=
